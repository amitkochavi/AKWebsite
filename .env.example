# ── Supabase ──────────────────────────────────────────────────────────────
# Project URL and keys from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Server-only. NEVER prefix with NEXT_PUBLIC. Used only in server actions/admin.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site ──────────────────────────────────────────────────────────────────
# The canonical public URL (used for SEO canonical/hreflang/sitemap).
NEXT_PUBLIC_SITE_URL=https://amitkochavi.com

# Shared secret to authorize on-demand revalidation calls.
REVALIDATE_SECRET=change-me-to-a-long-random-string
